---
/**
 * Datacat marketing landing page.
 *
 * One self-contained component rendered by both `index.mdx` (English) and `fr/index.mdx`
 * (French). All visible strings live in the `STRINGS` dictionary so the two languages stay
 * structurally identical; pass `lang="en" | "fr"`. Styling is scoped to this component;
 * site-wide brand tokens live in `src/styles/theme.css`.
 */
import { Code } from 'astro:components';

interface Props {
  lang?: 'en' | 'fr';
}
const { lang = 'en' } = Astro.props;

// BASE_URL may come without a trailing slash (e.g. "/datacat"); normalise so links don't
// collapse into "/datacatstart/" instead of "/datacat/start/".
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const link = (slug: string) => `${base}${lang === 'fr' ? 'fr/' : ''}${slug}`;

const eventSnippet = `import { createDatacatClient } from "@datacat/sdk-web";

const datacat = createDatacatClient({
  endpoint: "https://ingest.example.com/v1/events",
  getToken: () => fetch("/api/analytics-token").then((r) => r.text()),
});

datacat.identify({ actorId: "user-123", tenantId: "clinic-7" });
datacat.track("appointment_booked", { duration_ms: 412 });`;

const otlpSnippet = `# Any OpenTelemetry exporter works — point it at Datacat.
curl -X POST https://ingest.example.com/v1/logs \\
  -H "Authorization: Bearer $SERVICE_TOKEN" \\
  -H "Content-Type: application/json" \\
  -d @logs.otlp.json
# Logs, traces and metrics: OTLP over HTTP and gRPC.`;

const querySnippet = `-- Hot reads hit PostgreSQL directly; cold reads scan Parquet on S3.
SELECT event_name, count(*) AS n
FROM   events
WHERE  event_time > now() - interval '24 hours'
GROUP  BY event_name
ORDER  BY n DESC;`;

const STRINGS = {
  en: {
    eyebrow: 'Self-hosted analytics & observability',
    titleLead: 'Own your analytics.',
    titleAccent: 'One Postgres, zero lock-in.',
    subtitle:
      'Datacat is a self-hosted ingestion platform for events, logs, traces and metrics — strictly idempotent, OpenTelemetry-native, and built on PostgreSQL alone.',
    ctaPrimary: 'Get started',
    ctaSecondary: 'Quickstart',
    ctaGithub: 'View on GitHub',
    stack: 'Rust · PostgreSQL · OpenTelemetry · self-hosted',
    termTitle: 'track-event.ts',
    pillars: [
      { k: 'Idempotent by design', v: 'Exactly-once, even across retries.' },
      { k: 'PostgreSQL only', v: 'No Kafka, ClickHouse or Zookeeper.' },
      { k: 'OpenTelemetry native', v: 'OTLP over HTTP and gRPC.' },
      { k: 'HDS-grade security', v: 'Asymmetric tokens, strict validation.' },
    ],
    signalsTitle: 'One pipeline, four signals',
    signalsSub: 'Product events and full observability, correlated by tenant, actor and session.',
    signals: [
      { name: 'Events', desc: 'Product analytics with deterministic, idempotent IDs.' },
      { name: 'Logs', desc: 'OTLP logs, flattened and correlated to traces.' },
      { name: 'Traces', desc: 'Spans over HTTP & gRPC, linked by trace_id.' },
      { name: 'Metrics', desc: 'Gauges, sums and histograms from OTLP.' },
    ],
    featuresTitle: 'Built for the write path',
    featuresSub: 'A robust, auditable ingestion core — light now, scalable later.',
    features: [
      {
        t: 'Ingestion-first',
        d: 'COPY into UNLOGGED staging, micro-batching and time-partitioned tables. Tolerant to losing a tiny fraction of events — never to duplicates.',
      },
      {
        t: 'PostgreSQL only',
        d: 'One database as the central store. Clean boundaries between ingestion, storage and reads keep it light now and scalable later.',
      },
      {
        t: 'Strictly idempotent',
        d: 'A given event_id (or log / span / metric identity) counts exactly once, enforced at the storage layer with ON CONFLICT DO NOTHING.',
      },
      {
        t: 'OpenTelemetry native',
        d: 'Ingest OTLP logs, traces and metrics over HTTP and gRPC, correlated with product events. A read layer and an embedded MCP server.',
      },
      {
        t: 'Auditable & secure',
        d: 'Strict input validation, a public endpoint defended server-side, asymmetric token verification (public key only), TLS, secrets in the environment.',
      },
      {
        t: 'Configurable alerting',
        d: 'Per-project rules: error rates, latency percentiles, heartbeats, spikes, composite conditions, new-error detection and anomalies — to Slack, e-mail or webhooks.',
      },
    ],
    pipelineTitle: 'How ingestion works',
    pipelineSub: 'From SDK to durable, partitioned storage — and out to cold Parquet.',
    pipeline: [
      { t: 'SDK / OTLP', d: 'Web & Flutter SDKs, or any OpenTelemetry exporter.' },
      { t: 'HTTP + gRPC API', d: 'Validated, authenticated, rate-limited intake.' },
      { t: 'UNLOGGED staging', d: 'COPY a micro-batch for maximum write throughput.' },
      { t: 'Idempotent merge', d: 'ON CONFLICT DO NOTHING — duplicates collapse.' },
      { t: 'Partitioned tables', d: 'Time-partitioned PostgreSQL, ready to read hot.' },
      { t: 'Cold export', d: 'Scheduled Parquet on S3 for cheap long-term scans.' },
    ],
    codeTitle: 'Send anything. Read it anywhere.',
    codeSub: 'A few lines to start ingesting; SQL or MCP to read it back.',
    codeTabs: [
      { label: 'Track an event', code: eventSnippet, lang: 'ts' },
      { label: 'Ship OTLP logs', code: otlpSnippet, lang: 'bash' },
      { label: 'Query', code: querySnippet, lang: 'sql' },
    ],
    finalTitle: 'Start ingesting in minutes',
    finalSub: 'Spin up PostgreSQL, point an SDK or OTLP exporter at Datacat, and own your data end to end.',
    finalPrimary: 'Read the quickstart',
    finalGithub: 'Star on GitHub',
  },
  fr: {
    eyebrow: 'Analytics & observabilité auto-hébergées',
    titleLead: 'Vos analytics, chez vous.',
    titleAccent: 'Un seul Postgres, zéro lock-in.',
    subtitle:
      "Datacat est une plateforme d'ingestion auto-hébergée pour events, logs, traces et métriques — strictement idempotente, native OpenTelemetry, et bâtie sur PostgreSQL seul.",
    ctaPrimary: 'Commencer',
    ctaSecondary: 'Démarrage rapide',
    ctaGithub: 'Voir sur GitHub',
    stack: 'Rust · PostgreSQL · OpenTelemetry · auto-hébergé',
    termTitle: 'track-event.ts',
    pillars: [
      { k: 'Idempotent par conception', v: 'Exactly-once, même après retries.' },
      { k: 'PostgreSQL uniquement', v: 'Ni Kafka, ni ClickHouse, ni Zookeeper.' },
      { k: 'Natif OpenTelemetry', v: 'OTLP en HTTP et gRPC.' },
      { k: 'Sécurité niveau HDS', v: 'Tokens asymétriques, validation stricte.' },
    ],
    signalsTitle: 'Un pipeline, quatre signaux',
    signalsSub: 'Events produit et observabilité complète, corrélés par tenant, acteur et session.',
    signals: [
      { name: 'Events', desc: 'Analytics produit avec des IDs déterministes et idempotents.' },
      { name: 'Logs', desc: 'Logs OTLP aplatis et corrélés aux traces.' },
      { name: 'Traces', desc: 'Spans en HTTP & gRPC, reliés par trace_id.' },
      { name: 'Métriques', desc: 'Gauges, sums et histogrammes depuis OTLP.' },
    ],
    featuresTitle: "Conçu pour le chemin d'écriture",
    featuresSub: "Un cœur d'ingestion robuste et auditable — léger maintenant, scalable plus tard.",
    features: [
      {
        t: 'Centré ingestion',
        d: "COPY vers une table de staging UNLOGGED, micro-batch et tables partitionnées par le temps. Tolérant à la perte d'une infime fraction d'events — jamais aux doublons.",
      },
      {
        t: 'PostgreSQL uniquement',
        d: 'Une seule base comme stockage central. Des frontières nettes entre ingestion, stockage et lecture : léger maintenant, scalable plus tard.',
      },
      {
        t: 'Strictement idempotent',
        d: "Un event_id donné (ou l'identité d'un log / span / point de métrique) ne compte qu'une fois, garanti au stockage via ON CONFLICT DO NOTHING.",
      },
      {
        t: 'Natif OpenTelemetry',
        d: "Ingestion OTLP des logs, traces et métriques en HTTP et gRPC, corrélés aux events produit. Une couche de lecture et un serveur MCP embarqué.",
      },
      {
        t: 'Auditable & sécurisé',
        d: "Validation stricte, endpoint public défendu côté serveur, vérification asymétrique du token (clé publique seule), TLS, secrets dans l'environnement.",
      },
      {
        t: 'Alerting configurable',
        d: "Règles par projet : taux d'erreur, percentiles, heartbeats, pics, conditions composites, détection de nouvelles erreurs et anomalies — vers Slack, e-mail ou webhooks.",
      },
    ],
    pipelineTitle: "Comment fonctionne l'ingestion",
    pipelineSub: "Du SDK au stockage partitionné durable — et jusqu'au Parquet froid.",
    pipeline: [
      { t: 'SDK / OTLP', d: 'SDKs Web & Flutter, ou tout exporteur OpenTelemetry.' },
      { t: 'API HTTP + gRPC', d: 'Admission validée, authentifiée, limitée en débit.' },
      { t: 'Staging UNLOGGED', d: 'COPY d’un micro-batch pour un débit d’écriture maximal.' },
      { t: 'Merge idempotent', d: 'ON CONFLICT DO NOTHING — les doublons fusionnent.' },
      { t: 'Tables partitionnées', d: 'PostgreSQL partitionné par le temps, lisible à chaud.' },
      { t: 'Export froid', d: 'Parquet planifié sur S3 pour des scans long terme.' },
    ],
    codeTitle: 'Envoyez tout. Lisez partout.',
    codeSub: 'Quelques lignes pour ingérer ; SQL ou MCP pour relire.',
    codeTabs: [
      { label: 'Tracer un event', code: eventSnippet, lang: 'ts' },
      { label: 'Envoyer des logs OTLP', code: otlpSnippet, lang: 'bash' },
      { label: 'Requêter', code: querySnippet, lang: 'sql' },
    ],
    finalTitle: 'Ingérez en quelques minutes',
    finalSub: 'Lancez PostgreSQL, pointez un SDK ou un exporteur OTLP vers Datacat, et maîtrisez vos données de bout en bout.',
    finalPrimary: 'Lire le démarrage rapide',
    finalGithub: 'Star sur GitHub',
  },
}[lang];

const GH = 'https://github.com/krikristoophe/datacat';
const tabId = `dc-tabs-${lang}`;
---

<div class="dc">
  {/* ───────────────────────── Hero ───────────────────────── */}
  <section class="dc-hero">
    <div class="dc-hero__glow" aria-hidden="true"></div>
    <div class="dc-hero__grid" aria-hidden="true"></div>
    <div class="dc-hero__inner">
      <div class="dc-hero__copy">
        <span class="dc-eyebrow">{STRINGS.eyebrow}</span>
        <h1 class="dc-hero__title">
          {STRINGS.titleLead}<br />
          <span class="dc-grad">{STRINGS.titleAccent}</span>
        </h1>
        <p class="dc-hero__sub">{STRINGS.subtitle}</p>
        <div class="dc-actions">
          <a class="dc-btn dc-btn--primary" href={link('start/')}>{STRINGS.ctaPrimary} →</a>
          <a class="dc-btn dc-btn--ghost" href={link('quickstart/')}>{STRINGS.ctaSecondary}</a>
          <a class="dc-btn dc-btn--ghost" href={GH} target="_blank" rel="noopener">{STRINGS.ctaGithub} ↗</a>
        </div>
        <p class="dc-stack">{STRINGS.stack}</p>
      </div>

      <div class="dc-term" aria-hidden="false">
        <div class="dc-term__bar">
          <span class="dc-dot dc-dot--r"></span>
          <span class="dc-dot dc-dot--y"></span>
          <span class="dc-dot dc-dot--g"></span>
          <span class="dc-term__name">{STRINGS.termTitle}</span>
        </div>
        <div class="dc-term__body">
          <Code code={eventSnippet} lang="ts" theme="github-dark-default" />
        </div>
      </div>
    </div>

    <ul class="dc-pillars">
      {STRINGS.pillars.map((p) => (
        <li class="dc-pillar">
          <strong>{p.k}</strong>
          <span>{p.v}</span>
        </li>
      ))}
    </ul>
  </section>

  {/* ─────────────────────── Signals ─────────────────────── */}
  <section class="dc-section">
    <header class="dc-head">
      <h2>{STRINGS.signalsTitle}</h2>
      <p>{STRINGS.signalsSub}</p>
    </header>
    <div class="dc-signals">
      {STRINGS.signals.map((s) => (
        <div class="dc-signal">
          <span class="dc-signal__name">{s.name}</span>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─────────────────────── Features ────────────────────── */}
  <section class="dc-section">
    <header class="dc-head">
      <h2>{STRINGS.featuresTitle}</h2>
      <p>{STRINGS.featuresSub}</p>
    </header>
    <div class="dc-features">
      {STRINGS.features.map((f, i) => (
        <article class="dc-card">
          <span class="dc-card__chip">{String(i + 1).padStart(2, '0')}</span>
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ─────────────────────── Pipeline ────────────────────── */}
  <section class="dc-section dc-section--alt">
    <header class="dc-head">
      <h2>{STRINGS.pipelineTitle}</h2>
      <p>{STRINGS.pipelineSub}</p>
    </header>
    <ol class="dc-flow">
      {STRINGS.pipeline.map((step, i) => (
        <li class="dc-step">
          <span class="dc-step__num">{i + 1}</span>
          <h3>{step.t}</h3>
          <p>{step.d}</p>
        </li>
      ))}
    </ol>
  </section>

  {/* ─────────────────────── Code showcase ───────────────── */}
  <section class="dc-section">
    <header class="dc-head">
      <h2>{STRINGS.codeTitle}</h2>
      <p>{STRINGS.codeSub}</p>
    </header>
    <div class="dc-code" id={tabId}>
      <div class="dc-code__tabs" role="tablist">
        {STRINGS.codeTabs.map((tab, i) => (
          <button
            class={`dc-code__tab${i === 0 ? ' is-active' : ''}`}
            data-i={i}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            type="button"
          >
            {tab.label}
          </button>
        ))}
      </div>
      <div class="dc-code__panels">
        {STRINGS.codeTabs.map((tab, i) => (
          <div class={`dc-code__panel${i === 0 ? ' is-active' : ''}`} data-i={i} role="tabpanel">
            <Code code={tab.code} lang={tab.lang as any} theme="github-dark-default" />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─────────────────────── Final CTA ───────────────────── */}
  <section class="dc-cta">
    <div class="dc-cta__inner">
      <h2>{STRINGS.finalTitle}</h2>
      <p>{STRINGS.finalSub}</p>
      <div class="dc-actions dc-actions--center">
        <a class="dc-btn dc-btn--primary" href={link('quickstart/')}>{STRINGS.finalPrimary} →</a>
        <a class="dc-btn dc-btn--ghost" href={GH} target="_blank" rel="noopener">{STRINGS.finalGithub} ★</a>
      </div>
    </div>
  </section>
</div>

<script is:inline define:vars={{ tabId }}>
  (() => {
    const root = document.getElementById(tabId);
    if (!root) return;
    const tabs = root.querySelectorAll('.dc-code__tab');
    const panels = root.querySelectorAll('.dc-code__panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const i = tab.getAttribute('data-i');
        tabs.forEach((t) => {
          const active = t === tab;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-i') === i));
      });
    });
  })();
</script>

<style>
  /* The landing breaks out of Starlight's narrow splash column. */
  .dc {
    --dc-edge: rgba(255, 255, 255, 0.09);
    --dc-card: rgba(255, 255, 255, 0.025);
    margin-inline: auto;
    max-width: 1120px;
    padding-inline: 1.25rem;
  }
  :global([data-theme='light']) .dc {
    --dc-edge: rgba(15, 12, 40, 0.1);
    --dc-card: rgba(15, 12, 40, 0.02);
  }

  /* ── Hero ── */
  .dc-hero {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 5rem) 2.5rem;
    overflow: clip;
  }
  .dc-hero__glow {
    position: absolute;
    inset: -30% -20% auto -20%;
    height: 620px;
    background:
      radial-gradient(40% 55% at 22% 30%, rgba(139, 92, 255, 0.32), transparent 70%),
      radial-gradient(38% 50% at 78% 18%, rgba(34, 211, 238, 0.22), transparent 70%);
    filter: blur(8px);
    z-index: 0;
    pointer-events: none;
  }
  .dc-hero__grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--dc-edge) 1px, transparent 1px),
      linear-gradient(90deg, var(--dc-edge) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(70% 60% at 50% 0%, #000 30%, transparent 75%);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  .dc-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .dc-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-text-accent);
    border: 1px solid var(--dc-edge);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    background: var(--dc-gradient-soft);
  }
  .dc-hero__title {
    font-size: clamp(2.3rem, 5.4vw, 3.7rem);
    line-height: 1.04;
    margin: 1.1rem 0 0;
    font-weight: 700;
  }
  .dc-grad {
    background: var(--dc-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .dc-hero__sub {
    color: var(--sl-color-gray-2);
    font-size: clamp(1.02rem, 1.6vw, 1.22rem);
    line-height: 1.6;
    margin: 1.1rem 0 0;
    max-width: 38ch;
  }
  .dc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }
  .dc-actions--center {
    justify-content: center;
  }
  .dc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 10px;
    padding: 0.62rem 1.05rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1px solid var(--dc-edge);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .dc-btn--primary {
    background: var(--dc-gradient);
    color: #0b0a12;
    border: none;
    box-shadow: 0 10px 28px -12px rgba(124, 92, 255, 0.8);
  }
  .dc-btn--primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
  }
  .dc-btn--ghost {
    color: var(--sl-color-white);
    background: var(--dc-card);
  }
  .dc-btn--ghost:hover {
    border-color: var(--dc-violet);
    transform: translateY(-1px);
  }
  .dc-stack {
    margin-top: 1.3rem;
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
  }

  /* Terminal card — always a dark IDE surface, in both colour schemes. */
  .dc-term {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    background: #0d1117;
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.7);
    overflow: hidden;
  }
  .dc-term__bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
  }
  .dc-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .dc-dot--r { background: #ff5f57; }
  .dc-dot--y { background: #febc2e; }
  .dc-dot--g { background: #28c840; }
  .dc-term__name {
    margin-left: 0.5rem;
    font-size: 0.78rem;
    color: #8b94a7;
    font-family: var(--sl-font-mono, monospace);
  }
  .dc-term__body :global(pre) {
    margin: 0;
    border-radius: 0;
    border: none;
    background: transparent !important;
    font-size: 0.84rem;
    padding: 1rem 1.1rem;
  }

  /* Pillars strip */
  .dc-pillars {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: clamp(2rem, 5vw, 3.2rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.85rem;
  }
  .dc-pillar {
    border: 1px solid var(--dc-edge);
    border-radius: 12px;
    padding: 0.95rem 1rem;
    background: var(--dc-card);
  }
  .dc-pillar strong {
    display: block;
    font-size: 0.95rem;
  }
  .dc-pillar span {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.84rem;
    color: var(--sl-color-gray-3);
    line-height: 1.45;
  }

  /* ── Generic section ── */
  .dc-section {
    padding-block: clamp(2.4rem, 6vw, 4.2rem);
  }
  .dc-section--alt {
    border-radius: 22px;
    background: var(--dc-gradient-soft);
    border: 1px solid var(--dc-edge);
    padding-inline: clamp(1rem, 4vw, 2.6rem);
  }
  .dc-head {
    text-align: center;
    max-width: 52ch;
    margin: 0 auto clamp(1.6rem, 4vw, 2.6rem);
  }
  .dc-head h2 {
    font-size: clamp(1.7rem, 3.4vw, 2.4rem);
    margin: 0;
    border: none;
  }
  .dc-head p {
    color: var(--sl-color-gray-2);
    margin: 0.7rem 0 0;
    font-size: 1.04rem;
    line-height: 1.6;
  }

  /* Signals */
  .dc-signals {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
  }
  .dc-signal {
    border: 1px solid var(--dc-edge);
    border-radius: 14px;
    padding: 1.1rem 1.15rem;
    background: var(--dc-card);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .dc-signal:hover {
    transform: translateY(-3px);
    border-color: var(--dc-violet);
  }
  .dc-signal__name {
    font-family: 'Space Grotesk', var(--sl-font);
    font-weight: 700;
    font-size: 1.18rem;
    background: var(--dc-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .dc-signal p {
    margin: 0.5rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Features */
  .dc-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .dc-card {
    position: relative;
