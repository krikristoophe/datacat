# Datacat — variables d'environnement (copier en `.env`, ne JAMAIS committer de secrets réels).
#
# Depuis la config unifiée TOML, le déploiement se configure dans `datacat.toml`
# (modèle : `datacat.example.toml`) et les projets dans `projects/*.toml`. Les secrets n'y
# sont pas écrits en clair : ils sont référencés via `${VAR}` et résolus depuis cet environnement.
#
# Ce fichier ne contient donc que des SECRETS + le bootstrap. (Sans `datacat.toml`, le service
# retombe sur l'ancienne config 100 % variables d'environnement — voir docs/configuration.md.)

# ── Bootstrap ───────────────────────────────────────────────────────────────
# Chemin du fichier de config (sinon ./datacat.toml puis /etc/datacat/datacat.toml).
# DATACAT_CONFIG=/etc/datacat/datacat.toml
RUST_LOG=info,datacat_ingest=info,sqlx=warn
LOG_FORMAT=json

# ── Secrets référencés par datacat.toml via ${...} ──────────────────────────
# Base de données (obligatoire).
DATABASE_URL=postgres://datacat:datacat@localhost:55432/datacat

# Clé PUBLIQUE de vérification du token (au choix : PEM inline, fichier, ou JWKS dans le TOML).
# TOKEN_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Tokens de service statiques (auth service-à-service), si mode = static/auto.
# LOGS_STATIC_TOKEN=remplace-par-un-secret-de-service-long-et-aleatoire
# QUERY_TOKEN=remplace-par-un-secret-de-lecture-long-et-aleatoire

# Canaux de notification globaux (repli des projets). Slack = API Web (bot token + canal).
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=#alerts
# SMTP_USERNAME=alertes@example.com
# SMTP_PASSWORD=...

# Notifications par projet (référencées dans projects/*.toml).
# EXAMPLE_SLACK_BOT_TOKEN=xoxb-your-bot-token
# EXAMPLE_WEBHOOK_URL=https://hooks.internal.example/datacat
# EXAMPLE_WEBHOOK_TOKEN=...

# ── Export froid (si [export].enabled = true) ───────────────────────────────
# S3_ENDPOINT=https://s3.eu-west-1.amazonaws.com   # vide = AWS ; renseigner pour MinIO
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
