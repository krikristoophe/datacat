---
/**
 * Datacat marketing landing page.
 *
 * A SALES page (not technical docs): hero, value proposition (data sovereignty / compliance),
 * benefit grid, the four signals, and a CTA. One self-contained component rendered by both
 * `index.mdx` (English) and `fr/index.mdx` (French); all visible strings live in `STRINGS` so the
 * two languages stay structurally identical. Styling is scoped here; brand tokens live in
 * `src/styles/theme.css`.
 */
import { Code } from 'astro:components';

interface Props {
  lang?: 'en' | 'fr';
}
const { lang = 'en' } = Astro.props;

// BASE_URL may come without a trailing slash (e.g. "/datacat"); normalise so links don't
// collapse into "/datacatstart/" instead of "/datacat/start/".
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const link = (slug: string) => `${base}${lang === 'fr' ? 'fr/' : ''}${slug}`;

// The only code on the page: a "look how little it takes" hero snippet (sells ease of adoption).
// Short lines on purpose: this sits in a fixed-width hero card, so keep every line
// comfortably under ~54 chars to avoid horizontal clipping.
const eventSnippet = `import { createDatacatClient } from "@datacat/sdk-web";

const datacat = createDatacatClient({
  endpoint: "https://you.example.com/v1/events",
  getToken: () => fetchToken(),  // your short-lived JWT
});

datacat.identify({ actorId: "user-123" });
datacat.track("booking_confirmed", { ms: 412 });`;

const STRINGS = {
  en: {
    eyebrow: 'Self-hosted analytics & observability',
    titleLead: 'Own your analytics.',
    titleAccent: 'One Postgres, zero lock-in.',
    subtitle:
      "Self-host product events, logs, traces and metrics on PostgreSQL alone — and keep your users' data on your own infrastructure. Built to an HDS-grade security posture.",
    ctaPrimary: 'Get started',
    ctaSecondary: 'Quickstart',
    ctaGithub: 'View on GitHub',
    stack: 'Rust · PostgreSQL · OpenTelemetry · self-hosted',
    termTitle: 'track-event.ts',
    pillars: [
      { k: 'Own your data', v: 'Self-hosted — nothing leaves your infra.' },
      { k: 'PostgreSQL only', v: 'No Kafka, ClickHouse or Zookeeper.' },
      { k: 'All four signals', v: 'Events, logs, traces & metrics.' },
      { k: 'HDS-grade security', v: 'For sensitive, regulated data.' },
    ],
    valueTitle: 'Your data, your rules.',
    valueSub:
      'Most analytics and monitoring means shipping your users’ data to a third party. Datacat runs on your own infrastructure — so you stay in control.',
    values: [
      {
        t: 'Nothing leaves your infrastructure',
        d: 'No third-party SaaS, no data shipped offshore. You remain the data controller — built for sensitive, regulated workloads like health data (HDS) and GDPR.',
      },
      {
        t: 'No lock-in, no per-event bill',
        d: 'Open and self-hosted on your own PostgreSQL. Your schema, your retention, predictable cost — not a metered subscription that grows with your traffic.',
      },
      {
        t: 'Product and ops, together',
        d: 'Analytics events and full observability — logs, traces and metrics — in one correlated platform, instead of four disconnected tools and four invoices.',
      },
    ],
    featuresTitle: 'Everything you need, nothing to babysit.',
    featuresSub: 'A focused platform that is simple to run and built to last.',
    features: [
      {
        t: 'Never count an event twice',
        d: 'Strict idempotency means retries and flaky networks never inflate your numbers — each event lands exactly once.',
      },
      {
        t: 'Runs on PostgreSQL alone',
        d: 'No Kafka, ClickHouse or Zookeeper to operate. Deploy with a database you already know and trust.',
      },
      {
        t: 'Works with your stack',
        d: 'OpenTelemetry-native: point any OTel SDK or Collector at Datacat over HTTP or gRPC. Web and Flutter SDKs included.',
      },
      {
        t: 'Built for sensitive data',
        d: 'Strict input validation, asymmetric token verification, TLS everywhere, and an auditable, HDS-grade security posture.',
      },
      {
        t: 'Alerting that fits your team',
        d: 'Error rates, latency, heartbeats, spikes and anomalies — routed to Slack, e-mail or webhooks, per project.',
      },
      {
        t: 'Scales when you do',
        d: 'High-throughput ingestion today, with scheduled cold export to Parquet on S3 for cheap, long-term storage.',
      },
    ],
    signalsTitle: 'One platform, four signals.',
    signalsSub:
      'Product analytics and full observability — correlated by tenant, user and session, not scattered across four tools.',
    signals: [
      { name: 'Events', desc: 'Product analytics you fully own.' },
      { name: 'Logs', desc: 'Application logs, correlated to traces.' },
      { name: 'Traces', desc: 'Distributed traces across services.' },
      { name: 'Metrics', desc: 'Latency, throughput and custom metrics.' },
    ],
    finalTitle: 'Own your analytics today.',
    finalSub: "Self-host Datacat on PostgreSQL and keep full control of your users' data.",
    finalPrimary: 'Get started',
    finalGithub: 'Star on GitHub',
  },
  fr: {
    eyebrow: 'Analytics & observabilité auto-hébergées',
    titleLead: 'Vos analytics, chez vous.',
    titleAccent: 'Un seul Postgres, zéro lock-in.',
    subtitle:
      "Auto-hébergez events produit, logs, traces et métriques sur PostgreSQL seul — et gardez les données de vos utilisateurs sur votre propre infrastructure. Conçu pour une posture de sécurité niveau HDS.",
    ctaPrimary: 'Commencer',
    ctaSecondary: 'Démarrage rapide',
    ctaGithub: 'Voir sur GitHub',
    stack: 'Rust · PostgreSQL · OpenTelemetry · auto-hébergé',
    termTitle: 'track-event.ts',
    pillars: [
      { k: 'Vos données vous appartiennent', v: 'Auto-hébergé — rien ne sort de chez vous.' },
      { k: 'PostgreSQL uniquement', v: 'Ni Kafka, ni ClickHouse, ni Zookeeper.' },
      { k: 'Les quatre signaux', v: 'Events, logs, traces & métriques.' },
      { k: 'Sécurité niveau HDS', v: 'Pour des données sensibles et régulées.' },
    ],
    valueTitle: 'Vos données, vos règles.',
    valueSub:
      "La plupart des outils d'analytics et de monitoring envoient les données de vos utilisateurs à un tiers. Datacat tourne sur votre propre infrastructure — vous gardez le contrôle.",
    values: [
      {
        t: 'Rien ne sort de votre infrastructure',
        d: "Aucun SaaS tiers, aucune donnée envoyée à l'étranger. Vous restez responsable de traitement — conçu pour des charges sensibles et régulées : données de santé (HDS), RGPD.",
      },
      {
        t: 'Zéro lock-in, pas de facture à l’event',
        d: "Ouvert et auto-hébergé sur votre PostgreSQL. Votre schéma, votre rétention, un coût prévisible — pas un abonnement à l'usage qui gonfle avec votre trafic.",
      },
      {
        t: 'Produit et ops, ensemble',
        d: "Events analytics et observabilité complète — logs, traces et métriques — dans une plateforme corrélée, au lieu de quatre outils déconnectés et quatre factures.",
      },
    ],
    featuresTitle: "Tout ce qu'il faut, rien à surveiller.",
    featuresSub: 'Une plateforme ciblée, simple à exploiter et faite pour durer.',
    features: [
      {
        t: 'Jamais un event compté deux fois',
        d: "L'idempotence stricte fait que retries et réseaux instables ne gonflent jamais vos chiffres — chaque event ne compte qu'une fois.",
      },
      {
        t: 'Tourne sur PostgreSQL seul',
        d: 'Ni Kafka, ni ClickHouse, ni Zookeeper à exploiter. Déployez avec une base que vous connaissez déjà.',
      },
      {
        t: 'Compatible avec votre stack',
        d: 'Natif OpenTelemetry : pointez n’importe quel SDK ou Collector OTel vers Datacat, en HTTP ou gRPC. SDKs Web et Flutter inclus.',
      },
      {
        t: 'Conçu pour les données sensibles',
        d: 'Validation stricte des entrées, vérification asymétrique du token, TLS partout, et une posture de sécurité auditable niveau HDS.',
      },
      {
        t: 'Un alerting adapté à votre équipe',
        d: "Taux d'erreur, latence, heartbeats, pics et anomalies — routés vers Slack, e-mail ou webhooks, par projet.",
      },
      {
        t: 'Scalable quand vous grandissez',
        d: 'Ingestion à haut débit aujourd’hui, avec export froid planifié vers Parquet sur S3 pour un stockage long terme économique.',
      },
    ],
    signalsTitle: 'Une plateforme, quatre signaux.',
    signalsSub:
      'Analytics produit et observabilité complète — corrélés par tenant, utilisateur et session, au lieu d’être éparpillés sur quatre outils.',
    signals: [
      { name: 'Events', desc: 'Des analytics produit qui vous appartiennent.' },
      { name: 'Logs', desc: 'Logs applicatifs, corrélés aux traces.' },
      { name: 'Traces', desc: 'Traces distribuées entre services.' },
      { name: 'Métriques', desc: 'Latence, débit et métriques métier.' },
    ],
    finalTitle: 'Reprenez le contrôle de vos analytics.',
    finalSub: 'Auto-hébergez Datacat sur PostgreSQL et gardez la maîtrise totale des données de vos utilisateurs.',
    finalPrimary: 'Commencer',
    finalGithub: 'Star sur GitHub',
  },
}[lang];

const GH = 'https://github.com/krikristoophe/datacat';
---

<div class="dc">
  {/* ───────────────────────── Hero ───────────────────────── */}
  <section class="dc-hero">
    <div class="dc-hero__glow" aria-hidden="true"></div>
    <div class="dc-hero__grid" aria-hidden="true"></div>
    <div class="dc-hero__inner">
      <div class="dc-hero__copy">
        <span class="dc-eyebrow">{STRINGS.eyebrow}</span>
        <h1 class="dc-hero__title">
          {STRINGS.titleLead}<br />
          <span class="dc-grad">{STRINGS.titleAccent}</span>
        </h1>
        <p class="dc-hero__sub">{STRINGS.subtitle}</p>
        <div class="dc-actions">
          <a class="dc-btn dc-btn--primary" href={link('start/')}>{STRINGS.ctaPrimary} →</a>
          <a class="dc-btn dc-btn--ghost" href={link('quickstart/')}>{STRINGS.ctaSecondary}</a>
          <a class="dc-btn dc-btn--ghost" href={GH} target="_blank" rel="noopener">{STRINGS.ctaGithub} ↗</a>
        </div>
        <p class="dc-stack">{STRINGS.stack}</p>
      </div>

      <div class="dc-term">
        <div class="dc-term__bar">
          <span class="dc-dot dc-dot--r"></span>
          <span class="dc-dot dc-dot--y"></span>
          <span class="dc-dot dc-dot--g"></span>
          <span class="dc-term__name">{STRINGS.termTitle}</span>
        </div>
        <div class="dc-term__body">
          <Code code={eventSnippet} lang="ts" theme="github-dark-default" />
        </div>
      </div>
    </div>

    <ul class="dc-pillars">
      {STRINGS.pillars.map((p) => (
        <li class="dc-pillar">
          <strong>{p.k}</strong>
          <span>{p.v}</span>
        </li>
      ))}
    </ul>
  </section>

  {/* ───────────── Value proposition (data sovereignty) ───────────── */}
  <section class="dc-section dc-section--alt">
    <header class="dc-head">
      <h2>{STRINGS.valueTitle}</h2>
      <p>{STRINGS.valueSub}</p>
    </header>
    <div class="dc-features dc-features--three">
      {STRINGS.values.map((v) => (
        <article class="dc-card dc-card--plain">
          <h3>{v.t}</h3>
          <p>{v.d}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ─────────────────────── Benefits ────────────────────── */}
  <section class="dc-section">
    <header class="dc-head">
      <h2>{STRINGS.featuresTitle}</h2>
      <p>{STRINGS.featuresSub}</p>
    </header>
    <div class="dc-features">
      {STRINGS.features.map((f) => (
        <article class="dc-card dc-card--plain">
          <h3>{f.t}</h3>
          <p>{f.d}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ─────────────────────── Signals ─────────────────────── */}
  <section class="dc-section">
    <header class="dc-head">
      <h2>{STRINGS.signalsTitle}</h2>
      <p>{STRINGS.signalsSub}</p>
    </header>
    <div class="dc-signals">
      {STRINGS.signals.map((s) => (
        <div class="dc-signal">
          <span class="dc-signal__name">{s.name}</span>
          <p>{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ─────────────────────── Final CTA ───────────────────── */}
  <section class="dc-cta">
    <div class="dc-cta__inner">
      <h2>{STRINGS.finalTitle}</h2>
      <p>{STRINGS.finalSub}</p>
      <div class="dc-actions dc-actions--center">
        <a class="dc-btn dc-btn--primary" href={link('start/')}>{STRINGS.finalPrimary} →</a>
        <a class="dc-btn dc-btn--ghost" href={GH} target="_blank" rel="noopener">{STRINGS.finalGithub} ★</a>
      </div>
    </div>
  </section>
</div>

<style>
  /* The landing breaks out of Starlight's narrow splash column. */
  .dc {
    --dc-edge: rgba(255, 255, 255, 0.09);
    --dc-card: rgba(255, 255, 255, 0.025);
    margin-inline: auto;
    max-width: 1120px;
    padding-inline: 1.25rem;
  }
  :global([data-theme='light']) .dc {
    --dc-edge: rgba(15, 12, 40, 0.1);
    --dc-card: rgba(15, 12, 40, 0.02);
  }

  /* ── Hero ── */
  .dc-hero {
    position: relative;
    padding-block: clamp(2.5rem, 6vw, 5rem) 2.5rem;
    overflow: clip;
  }
  .dc-hero__glow {
    position: absolute;
    inset: -30% -20% auto -20%;
    height: 620px;
    background:
      radial-gradient(40% 55% at 22% 30%, rgba(139, 92, 255, 0.32), transparent 70%),
      radial-gradient(38% 50% at 78% 18%, rgba(34, 211, 238, 0.22), transparent 70%);
    filter: blur(8px);
    z-index: 0;
    pointer-events: none;
  }
  .dc-hero__grid {
    position: absolute;
    inset: 0;
    background-image: linear-gradient(var(--dc-edge) 1px, transparent 1px),
      linear-gradient(90deg, var(--dc-edge) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: radial-gradient(70% 60% at 50% 0%, #000 30%, transparent 75%);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
  }
  .dc-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .dc-eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-text-accent);
    border: 1px solid var(--dc-edge);
    border-radius: 999px;
    padding: 0.3rem 0.8rem;
    background: var(--dc-gradient-soft);
  }
  .dc-hero__title {
    font-size: clamp(2.3rem, 5.4vw, 3.7rem);
    line-height: 1.04;
    margin: 1.1rem 0 0;
    font-weight: 700;
  }
  .dc-grad {
    background: var(--dc-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .dc-hero__sub {
    color: var(--sl-color-gray-2);
    font-size: clamp(1.02rem, 1.6vw, 1.22rem);
    line-height: 1.6;
    margin: 1.1rem 0 0;
    max-width: 42ch;
  }
  .dc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }
  .dc-actions--center {
    justify-content: center;
  }
  .dc-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 10px;
    padding: 0.62rem 1.05rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border: 1px solid var(--dc-edge);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .dc-btn--primary {
    background: var(--dc-gradient);
    color: #0b0a12;
    border: none;
    box-shadow: 0 10px 28px -12px rgba(124, 92, 255, 0.8);
  }
  .dc-btn--primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.06);
  }
  .dc-btn--ghost {
    color: var(--sl-color-white);
    background: var(--dc-card);
  }
  .dc-btn--ghost:hover {
    border-color: var(--dc-violet);
    transform: translateY(-1px);
  }
  .dc-stack {
    margin-top: 1.3rem;
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
  }

  /* Terminal card — always a dark IDE surface, in both colour schemes. */
  .dc-term {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    background: #0d1117;
    box-shadow: 0 30px 60px -30px rgba(0, 0, 0, 0.7);
    overflow: hidden;
  }
  .dc-term__bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
  }
  .dc-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .dc-dot--r { background: #ff5f57; }
  .dc-dot--y { background: #febc2e; }
  .dc-dot--g { background: #28c840; }
  .dc-term__name {
    margin-left: 0.5rem;
    font-size: 0.78rem;
    color: #8b94a7;
    font-family: var(--sl-font-mono, monospace);
  }
  .dc-term__body :global(pre) {
    margin: 0;
    border-radius: 0;
    border: none;
    background: transparent !important;
    font-size: 0.8rem;
    padding: 1rem 1.1rem;
    overflow-x: auto; /* never clip if a line is long; scroll inside the card */
  }

  /* Pillars strip */
  .dc-pillars {
    position: relative;
    z-index: 1;
    list-style: none;
    margin: clamp(2rem, 5vw, 3.2rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: stretch;
    gap: 0.85rem;
  }
  .dc-pillar {
    height: 100%;
    border: 1px solid var(--dc-edge);
    border-radius: 12px;
    padding: 0.95rem 1rem;
    background: var(--dc-card);
  }
  .dc-pillar strong {
    display: block;
    font-size: 0.95rem;
  }
  .dc-pillar span {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.84rem;
    color: var(--sl-color-gray-3);
    line-height: 1.45;
  }

  /* ── Generic section ── */
  .dc-section {
    padding-block: clamp(2.4rem, 6vw, 4.2rem);
  }
  .dc-section--alt {
    border-radius: 22px;
    background: var(--dc-gradient-soft);
    border: 1px solid var(--dc-edge);
    padding-inline: clamp(1rem, 4vw, 2.6rem);
  }
  .dc-head {
    text-align: center;
    max-width: 56ch;
    margin: 0 auto clamp(1.6rem, 4vw, 2.6rem);
  }
  .dc-head h2 {
    font-size: clamp(1.7rem, 3.4vw, 2.4rem);
    margin: 0;
    border: none;
  }
  .dc-head p {
    color: var(--sl-color-gray-2);
    margin: 0.7rem 0 0;
    font-size: 1.04rem;
    line-height: 1.6;
  }

  /* Signals */
  .dc-signals {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: stretch;
    gap: 0.9rem;
  }
  .dc-signal {
    height: 100%;
    border: 1px solid var(--dc-edge);
    border-radius: 14px;
    padding: 1.1rem 1.15rem;
    background: var(--dc-card);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .dc-signal:hover {
    transform: translateY(-3px);
    border-color: var(--dc-violet);
  }
  .dc-signal__name {
    font-family: 'Space Grotesk', var(--sl-font);
    font-weight: 700;
    font-size: 1.18rem;
    background: var(--dc-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .dc-signal p {
    margin: 0.5rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Benefit / value cards */
  .dc-features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
    gap: 1rem;
  }
  .dc-card {
    height: 100%;
    position: relative;
    border: 1px solid var(--dc-edge);
    border-radius: 16px;
    padding: 1.4rem 1.3rem 1.3rem;
    background: var(--dc-card);
    overflow: hidden;
    transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
  }
  .dc-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--dc-gradient);
    opacity: 0;
    transition: opacity 0.16s ease;
  }
  .dc-card:hover {
    transform: translateY(-4px);
    border-color: transparent;
    box-shadow: 0 24px 50px -28px rgba(124, 92, 255, 0.6);
  }
  .dc-card:hover::before {
    opacity: 1;
  }
  .dc-card h3 {
    margin: 0;
    font-size: 1.15rem;
  }
  .dc-card p {
    margin: 0.5rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.92rem;
    line-height: 1.58;
  }

  /* Final CTA */
  .dc-cta {
    margin-block: clamp(2.5rem, 6vw, 4.5rem);
  }
  .dc-cta__inner {
    position: relative;
    text-align: center;
    border: 1px solid var(--dc-edge);
    border-radius: 24px;
    padding: clamp(2.2rem, 6vw, 3.6rem) 1.5rem;
    background:
      radial-gradient(60% 120% at 50% 0%, rgba(139, 92, 255, 0.22), transparent 70%),
      var(--dc-card);
    overflow: hidden;
  }
  .dc-cta__inner h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin: 0;
    border: none;
  }
  .dc-cta__inner p {
    color: var(--sl-color-gray-2);
    max-width: 52ch;
    margin: 0.8rem auto 0;
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .dc-cta__inner .dc-actions {
    margin-top: 1.7rem;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .dc-hero__inner { grid-template-columns: 1fr; }
    .dc-hero__sub { max-width: none; }
    .dc-pillars { grid-template-columns: repeat(2, 1fr); }
    .dc-signals { grid-template-columns: repeat(2, 1fr); }
    .dc-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .dc-pillars, .dc-signals, .dc-features { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .dc-btn, .dc-card, .dc-signal { transition: none; }
  }
</style>
