{
  "name": "@datacat/mcp-server",
  "version": "0.1.0",
  "description": "Serveur MCP donnant à Claude un accès lecture aux logs, traces, events et métriques de Datacat (debug, analyse de parcours, vérification).",
  "type": "module",
  "bin": {
    "datacat-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
