# Datacat — exemple de configuration (copier en `.env`, ne jamais committer de secrets réels).
# Toutes les variables ont une valeur par défaut sûre ; seul DATABASE_URL est obligatoire.

# ── Serveur ─────────────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:8080
REQUEST_TIMEOUT=15s
# Activer UNIQUEMENT derrière exactement un reverse-proxy de confiance.
TRUST_FORWARDED_FOR=false
LOG_FORMAT=json
RUST_LOG=info,datacat_ingest=info,sqlx=warn

# ── Base de données (obligatoire) ───────────────────────────────────────────
DATABASE_URL=postgres://datacat:datacat@localhost:55432/datacat
DB_MAX_CONNECTIONS=10

# ── Ingestion / micro-batch ─────────────────────────────────────────────────
FLUSH_INTERVAL=200ms
FLUSH_BATCH_SIZE=5000
CHANNEL_CAPACITY=100000

# ── Rétention / partitions ──────────────────────────────────────────────────
RETENTION_DAYS=90
PARTITION_FUTURE_DAYS=2

# ── Logs techniques OTLP (/v1/logs HTTP + gRPC) ─────────────────────────────
MAX_LOGS_RECORDS=2048
MAX_LOGS_PAYLOAD_BYTES=4194304
# Auth des logs (service-à-service) : auto | static | jwt | none.
# `static` recommandé : un token de service FIXE (les backends peuvent détenir un secret).
LOGS_AUTH=auto
# LOGS_STATIC_TOKEN=remplace-par-un-secret-de-service-long-et-aleatoire
# Serveur OTLP/gRPC (port 4317 standard). Désactivé par défaut.
GRPC_ENABLED=false
GRPC_BIND_ADDR=0.0.0.0:4317

# ── Validation des entrées ──────────────────────────────────────────────────
MAX_BATCH_EVENTS=500
MAX_PAYLOAD_BYTES=1048576
MAX_PROPERTIES_BYTES=16384
MAX_STRING_LEN=200
MAX_JSON_DEPTH=16
MAX_PAST_SKEW=31d
MAX_FUTURE_SKEW=24h

# ── Rate limiting (cahier §7.2) ─────────────────────────────────────────────
RL_GLOBAL_PER_SEC=50000
RL_GLOBAL_BURST=100000
RL_SESSION_PER_SEC=100
RL_SESSION_BURST=1000
RL_IP_SESSION_CAP=200
RL_IP_SESSION_WINDOW=30m
RL_MAX_TRACKED_SESSIONS=500000
RL_MAX_TRACKED_IPS=200000

# ── Détection d'anomalies (ban temporaire d'IP) ─────────────────────────────
ANOMALY_BAD_THRESHOLD=100
ANOMALY_WINDOW=60s
ANOMALY_BAN_DURATION=300s
ANOMALY_MAX_TRACKED_IPS=200000

# ── Vérification du token (clé PUBLIQUE uniquement) ─────────────────────────
TOKEN_ENABLED=true
TOKEN_ALGORITHMS=EdDSA,RS256
TOKEN_LEEWAY=60
# Vérifiés seulement s'ils sont définis :
# TOKEN_ISSUER=swappy-backend
# TOKEN_AUDIENCE=datacat-ingest
#
# Option A — clé PEM en configuration :
# TOKEN_ALG=EdDSA
# TOKEN_PUBLIC_KEY_FILE=/etc/datacat/ingest_pub.pem
# TOKEN_KID=2026-06-key-1
#
# Option B — JWKS (rotation sans redéploiement) :
# TOKEN_JWKS_URL=https://swappy-backend.example.com/.well-known/jwks.json
# TOKEN_JWKS_REFRESH=1h

# ── CORS ────────────────────────────────────────────────────────────────────
# Liste blanche d'origines (séparées par des virgules). `*` = dev uniquement.
CORS_ALLOWED_ORIGINS=https://app.example.com

# ── Couche de lecture (/v1/query/*) ─────────────────────────────────────────
# Auth des endpoints de lecture : auto | static | jwt | none.
QUERY_AUTH=auto
# QUERY_TOKEN=remplace-par-un-secret-de-lecture-long-et-aleatoire
# Endpoint SQL ad-hoc en LECTURE SEULE (utile pour le MCP/debug). Désactivé par défaut.
QUERY_SQL_ENABLED=false
QUERY_SQL_TIMEOUT=10s
QUERY_SQL_MAX_ROWS=1000
# Serveur MCP HTTP intégré (route /mcp), accès lecture pour un agent (Claude). Auth = query_auth.
MCP_ENABLED=true

# ── Alerting (optionnel ; désactivé sans règles ni action/notifier) ─────────
# Règles déclaratives (kinds log_count / log_group_count / metric_threshold) avec actions
# modulables par règle (slack/email/webhook). Voir backend/alert_rules.example.json + docs/alerting.md.
# ALERT_RULES_FILE=/etc/datacat/alert-rules.json
ALERT_EVAL_INTERVAL=60s
# Canaux globaux par défaut (utilisés par les règles sans `actions`) :
# Slack (webhook entrant)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Email (SMTP, TLS rustls)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=alertes@example.com
# SMTP_PASSWORD=...
# ALERT_EMAIL_FROM=alertes@example.com
# ALERT_EMAIL_TO=ops@example.com,oncall@example.com
